# Discord Webhook Configuration
# Copy this file to .env and fill in your actual webhook URL
# Get your webhook URL from Discord: Server Settings → Integrations → Webhooks
#
# IMPORTANT: Keep .env file secret! Never commit it to version control.

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_APPLICATION_ID=YOUR_APPLICATION_ID
DISCORD_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Smart Classroom API (for pushing detector data to Supabase)
CLASSROOM_API_URL=http://YOUR_PC_IP:8766
CLASSROOM_API_KEY=YOUR_SHARED_DETECTOR_KEY

# Supabase (only needed on the PC running classroom_api.py)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
